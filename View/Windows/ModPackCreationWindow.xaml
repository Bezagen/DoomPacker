<hc:Window x:Class="DoomPacker.View.Windows.ModPackCreationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DoomPacker.View.Windows"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Height="700" Width="600"
        WindowStyle="ToolWindow"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource RegionBrush}"
        FontSize="16"
        Title="Create new Modpack">
    <Grid>
        <Border
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            Background="{StaticResource RegionBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,2">
            <StackPanel
                Orientation="Horizontal">
                <hc:ImageSelector
                    Height="164"
                    Width="164"
                    Margin="10"/>
                <StackPanel
                    Margin="10"
                    Width="390">
                    <TextBlock 
                        Text="Title"
                        Foreground="White"/>
                    <TextBox />
                    <TextBlock
                        Text="Description"
                        Foreground="White"/>
                    <RichTextBox 
                        Height="90"
                        VerticalScrollBarVisibility="Visible"
                        >
                    </RichTextBox>
                </StackPanel>
            </StackPanel>
        </Border>
        <Border
            Background="{StaticResource SecondaryRegionBrush}"
            Margin="24, 220, 24, 44"
            CornerRadius="16">
            <Grid
                Margin="16">
                <TextBlock
                    Text="Mods folder"
                    Foreground="White"
                    VerticalAlignment="Top"
                    Margin="80,0,0,0"/>
                <TextBlock
                    Text="Mods in Modpack"
                    Foreground="White"
                    VerticalAlignment="Top"
                    Margin="335,0,0,0"/>
                <Border
                    Margin="0,24,0,0"
                    HorizontalAlignment="Left"
                    Width="250"
                    Background="{StaticResource RegionBrush}"
                    CornerRadius="8"
                    BorderBrush="{StaticResource SecondaryBorderBrush}"
                    BorderThickness="2">
                    <ListBox
                        Margin="4"
                        BorderThickness="0"
                        ItemsSource="{Binding ModsInFolder}"
                        SelectedItem="{Binding SelectedItemFolder, Mode=TwoWay}">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="MouseDoubleClick">
                                <b:InvokeCommandAction
                                    Command="{Binding FolderDoubleClickCommand}"
                                    CommandParameter="{Binding SelectedItemFolder}"/>
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ListBox>
                </Border>
                <Border
                    Margin="0,24,0,0"
                    HorizontalAlignment="Right"
                    Width="250"
                    Background="{StaticResource RegionBrush}"
                    CornerRadius="8"
                    BorderBrush="{StaticResource SecondaryBorderBrush}"
                    BorderThickness="2">
                    <ListBox
                        Margin="4"
                        BorderThickness="0"
                        ItemsSource="{Binding ModsInModPack}"
                        SelectedItem="{Binding SelectedItemPack, Mode=TwoWay}">
                        <b:Interaction.Triggers>
                            <b:EventTrigger EventName="MouseDoubleClick">
                                <b:InvokeCommandAction
                                    Command="{Binding PackDoubldeClickCommand}"
                                    CommandParameter="{Binding SelectedItemPack}"/>         
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                    </ListBox>
                </Border>
            </Grid>
        </Border>
        <Button
            Style="{StaticResource ButtonPrimary}"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="4"
            Content="Save"
            FontSize="16"
            Height="36"/>
    </Grid>
</hc:Window>
